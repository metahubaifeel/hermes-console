# Copy to .env or export before install/restart.
# All variables are optional.

# --- Hermes paths (auto-detected from systemd unit if unset) ---
# HERMES_HOME=/path/to/.hermes
# HERMES_VENV_PY=/path/to/hermes-agent/venv/bin/python

# --- Proxy (only if Discord is region-blocked) ---
# Default install: auto-detect local proxy port; use --skip-proxy for direct Discord.

# HERMES_WITH_PROXY=1          # force proxy drop-in
# HERMES_SKIP_PROXY=1          # force direct (no proxy in drop-in)
# HERMES_AUTO_PROXY=1          # enable proxy only when local port is listening (install default)

# HERMES_PROXY_PORT=7897       # local mixed/SOCKS port (Clash default is often 7897)
# HERMES_HTTP_PROXY=http://127.0.0.1:7897
# HERMES_DISCORD_PROXY=socks5://127.0.0.1:7897   # WebSocket needs SOCKS, not HTTP-only

# --- Timeouts ---
# HERMES_DISCORD_WAIT_SEC=180
# HERMES_NETWORK_WAIT_SEC=90
